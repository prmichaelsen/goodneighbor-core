{
  "name": "@prmichaelsen/goodneighbor-core",
  "version": "0.1.0",
  "description": "Platform-agnostic business logic library for Good Neighbor community platform",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./constants": {
      "types": "./dist/constants/collections.d.ts",
      "import": "./dist/constants/collections.js"
    },
    "./errors": {
      "types": "./dist/errors/app-errors.d.ts",
      "import": "./dist/errors/app-errors.js"
    },
    "./config": {
      "types": "./dist/config/schema.d.ts",
      "import": "./dist/config/schema.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./container": {
      "types": "./dist/container.d.ts",
      "import": "./dist/container.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.build.js",
    "build:watch": "node esbuild.watch.js",
    "clean": "rm -rf dist",
    "dev": "npm run build:watch",
    "test": "jest",
    "test:unit": "jest --testMatch='**/*.spec.ts'",
    "test:e2e": "jest --testMatch='**/*.e2e.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm run test:unit"
  },
  "keywords": [
    "goodneighbor",
    "community",
    "content-management",
    "firebase",
    "algolia",
    "search",
    "typescript",
    "business-logic",
    "service-container"
  ],
  "author": "Patrick Michaelsen",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prmichaelsen/firebase-admin-sdk-v8": "^2.5.1",
    "algoliasearch": "^5.49.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
